{
	"name": "jefr-cursor",
	"displayName": "jefr cursor",
	"description": "jefr cursor - Cursor AI side-panel chat via MCP",
	"version": "8.8.8",
	"publisher": "jefr",
	"license": "MIT",
	"engines": {
		"vscode": "^1.80.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": ["onStartupFinished"],
	"main": "./dist/extension.js",
	"contributes": {
		"viewsContainers": {
			"panel": [
				{
					"id": "mcpMessenger",
					"title": "jefr cursor",
					"icon": "media/icon.svg"
				}
			]
		},
		"views": {
			"mcpMessenger": [
				{
					"type": "webview",
					"id": "mcpMessenger.mainView",
					"name": "jefr cursor"
				}
			]
		},
		"commands": [
			{
				"command": "mcpMessenger.setupMcp",
				"title": "jefr cursor: Install MCP config"
			},
			{
				"command": "mcpMessenger.removeMcp",
				"title": "jefr cursor: Remove MCP config"
			},
			{
				"command": "mcpMessenger.sendFile",
				"title": "jefr cursor: Send file to queue"
			},
			{
				"command": "mcpMessenger.openConsole",
				"title": "jefr cursor: Open local console"
			}
		],
		"menus": {
			"explorer/context": [
				{
					"command": "mcpMessenger.sendFile",
					"group": "navigation@100"
				}
			]
		}
	},
	"scripts": {
		"compile:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
		"compile:css": "node -e \"require('fs').copyFileSync('src/webview/webview.css','dist/webview.css')\"",
		"compile:webview": "esbuild src/webview/index.tsx --bundle --outfile=dist/webview.js --format=iife --platform=browser --minify && npm run compile:css",
		"compile:mcp": "esbuild mcp-server/index.ts --bundle --outfile=dist/mcp-server.mjs --format=esm --platform=node",
		"compile": "npm run compile:ext && npm run compile:webview && npm run compile:mcp",
		"watch:ext": "npm run compile:ext -- --watch",
		"watch:webview": "npm run compile:webview -- --watch",
		"package": "npm run compile && npx @vscode/vsce package --no-dependencies"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.1"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@types/react": "^18.2.0",
		"@types/react-dom": "^18.2.0",
		"@types/vscode": "^1.80.0",
		"esbuild": "^0.20.0",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"typescript": "^5.0.0"
	}
}
